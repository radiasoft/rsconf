#!/bin/bash
#
# Starts mpiexec
#
set -eou pipefail
shopt -s nullglob
declare -a _rsmpi_ips=(
    '10.10.10.40'
    '10.10.10.50'
    '10.10.10.60'
)
declare -a _rsmpi_hosts=(
    'v4.radia.run'
    'v5.radia.run'
    'v6.radia.run'
)
declare -i _rsmpi_max_slots=6
declare -i _rsmpi_slots_per_host=2
_rsmpi_conf_d='/home/vagrant/jupyter/.rsmpi'
_rsmpi_known_hosts='/home/vagrant/jupyter/.rsmpi/known_hosts'
_rsmpi_net='10.10.10.0/24'
_rsmpi_ssh_config='/home/vagrant/jupyter/.rsmpi/ssh_config'


# allow overrides in deployment, but do not document in usage.
# should be fixed here, when there is a missing pattern. ^OMP_
# is necessary to avoid conflicts with OMPI_ (openmpi), which we
# don't want to pass.
: ${rsmpi_pass_env:='MODULE|^OMP_|PATH|PYENV|PYTHON|SYNERGIA|VIRTUAL'}
declare -i _rsmpi_num_hosts=${#_rsmpi_ips[@]}

_check_host() {
    declare h=$1
    declare x
    x=$(ssh -F "$_rsmpi_ssh_config" \
        -o BatchMode=yes \
        -o ConnectTimeout=2 \
        -o GlobalKnownHostsFile=/dev/null \
        -o IdentityFile="$_rsmpi_conf_d/$h"/identity \
        -o StrictHostKeyChecking=no \
        -o UserKnownHostsFile=/dev/null \
        "$h" 'find /dev/shm -mindepth 1 -delete 2>/dev/null || true; hostname' 2>/dev/null < /dev/null || true)
    if [[ $x != $h ]]; then
        _err "host $h is unavailable"
    fi
}

_err() {
    _msg "$@"
    exit 1
}

_exec_mpi() {
    declare hostfile=$1
    shift
    _setup_ssh_config
    declare a=
    declare x
    for x in $(compgen -A variable | grep -E "($rsmpi_pass_env)"); do
        a+=$x,
    done
    exec mpiexec -f "$hostfile" -localhost "$(_local_ip)" -envlist "${a[@]:0:-1}" "$@"
}

_help() {
    if (( $# > 0 )); then
        _msg "error: $*"
    fi
    declare h=$(seq --separator=, 1 "$_rsmpi_num_hosts")
    cat 1>&2 <<EOF
usage: rsmpi [-n processes] [-h hosts] [-t tasks-per-host] <mpi-command args...>

Starts mpiexec <mpi-command args...> with specified processes and hosts.

Options:
    hosts: indices of hosts to use; all hosts is $h [default]
    processes: integer between 1 and $_rsmpi_max_slots [default]
    tasks-per-host: integer between 1 and $_rsmpi_slots_per_host [default]

For more information, please visit:

https://github.com/radiasoft/devops/wiki/rsmpi

Available hosts:
EOF
    declare i
    for i in $(seq 1 "$_rsmpi_num_hosts"); do
        _msg "$i ${_rsmpi_hosts[i-1]}"
    done
    exit 1
}

_hostfile() {
    declare -i slots=$1
    shift
    declare -i tasks=$1
    shift
    declare -a hosts=( "$@" )
    if (( $# <= 0 )); then
        hosts=( $(seq 1 $_rsmpi_num_hosts) )
    fi
    declare t=/tmp/rsmpi_hosts-
    # Avoid collisions with parallel executions
    find "$t"* -mmin +60 -exec rm -f {} \; >& /dev/null || true
    declare i
    t+=$RANDOM$RANDOM
    if (( slots <= 0 )); then
        slots=$(( ${#hosts[@]} * _rsmpi_slots_per_host ))
    fi
    if (( tasks <= 0 )); then
        tasks=$_rsmpi_slots_per_host
    fi
    declare s
    for i in "${hosts[@]}"; do
        _check_host "${_rsmpi_hosts[i-1]}"
        slots=$(( slots - tasks ))
        s=$tasks
        if (( $slots < 0 )); then
            s=$(( s + slots ))
        fi
        echo "${_rsmpi_ips[i-1]}:$s"
        if (( $slots <= 0 )); then
            break
        fi
    done | install -m 400 /dev/stdin "$t"
    echo "$t"
}

_local_ip() {
    #TODO(robnagler) only works for class C
    declare n=${_rsmpi_net%0/*}
    n=^${n//./\\.}
    declare i
    for i in $(hostname -i); do
        if [[ $i =~ $n ]]; then
            echo $i
            return
        fi
    done
    _err "cannot determine local ip for network=$_rsmpi_net"
}

_main() {
    declare o OPTARG OPTIND=1 OPTERR h
    declare -i slots=0 tasks=0
    declare -a hosts=()
    while getopts "h:n:t:" o; do
        case $o in
            h)
                if [[ ! $OPTARG =~ ^[0-9,]+$ ]]; then
                    _help "invalid host spec: $OPTARG"
                fi
                IFS=, read -ra hosts <<<$OPTARG
                declare -A seen=()
                for h in "${hosts[@]}"; do
                    if (( h < 1 || h > _rsmpi_num_hosts )); then
                        _help "invalid host number: $h"
                    fi
                    if [[ ${seen[h]+1} ]]; then
                        _help "duplicate host number: $h"
                    fi
                    seen[$h]=1
                done
                if (( ${#hosts[@]} <= 0 )); then
                    _help "no hosts in: ${hosts[*]}"
                fi
                ;;
            n)
                if [[ ! $OPTARG =~ ^[0-9]+$ ]]; then
                    _help "process count must be a number: $OPTARG"
                fi
                slots=$OPTARG
                if (( slots < 1 || slots > _rsmpi_max_slots )); then
                    _help "invalid process count: $slots"
                fi
                ;;
            t)
                if [[ ! $OPTARG =~ ^[0-9]+$ ]]; then
                    _help "tasks-per-host count must be a number: $OPTARG"
                fi
                tasks=$OPTARG
                if (( tasks < 1 || tasks > _rsmpi_slots_per_host )); then
                    _help "invalid tasks-per-host count (max=$_rsmpi_slots_per_host): $tasks"
                fi
                ;;
            *)
                _help
                ;;
        esac
    done
    shift $((OPTIND -1))
    if (( $# <= 0 )); then
        _help 'missing command argument'
    fi
    _exec_mpi "$(_hostfile "$slots" "$tasks" ${hosts[@]+"${hosts[@]}"})" "$@"
}

_msg() {
    if (( $# )); then
        echo "$*" 1>&2
    fi
}

_setup_ssh_config() {
    declare d=$HOME/.ssh
    declare l=$d.lock
    declare i
    for i in $(seq 1 10); do
        if ! mkdir "$l" >& /dev/null; then
            if (( i == 9 )); then
                # remove the lock before last try, because
                # something is wrong. If it fails again, we
                # report the error
                rm -rf "$l"
            else
                sleep 1
            fi
            continue
        fi
        if [[ ! -d $d ]]; then
            install -d -m 700 "$d"
        fi
        _ssh_config_cp "$_rsmpi_ssh_config" "$d/config"
        _ssh_config_cp "$_rsmpi_known_hosts" "$d/known_hosts"
        rm -rf "$l"
        return
    done
    _err "unable to create lock=$l"
}

_ssh_config_cp() {
    declare src=$1
    declare dst=$2
    if ! cmp "$src" "$dst" >& /dev/null; then
        install -m 600 "$src" "$dst"
    fi
}

_main "$@"
